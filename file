<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>KUNCORO APP - Galactic Overdrive v2.0</title>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;700;800&display=swap" rel="stylesheet">
    <style>
        /* --- COSMIC FOUNDATION --- */
        * { box-sizing: border-box; margin: 0; padding: 0; }
        
        :root {
            --neon-pink: #ff0055;
            --neon-blue: #00d2ff;
            --neon-purple: #9d50bb;
            --space-dark: #020617;
        }

        body {
            font-family: 'Plus Jakarta Sans', sans-serif;
            background: #020617;
            color: #fff;
            display: flex;
            justify-content: center;
            align-items: flex-start;
            padding-top: 50px;
            min-height: 100vh;
            overflow-x: hidden;
            position: relative;
        }

        /* --- ANIMATED SPACE BACKGROUND --- */
        .nebula {
            position: fixed; top: 0; left: 0; width: 100%; height: 100%;
            background: 
                radial-gradient(circle at 20% 30%, rgba(157, 80, 187, 0.2), transparent 50%),
                radial-gradient(circle at 80% 70%, rgba(0, 210, 255, 0.2), transparent 50%);
            z-index: -2; animation: nebulaPulse 10s ease-in-out infinite alternate;
        }
        @keyframes nebulaPulse { to { transform: scale(1.3) rotate(10deg); opacity: 0.9; } }

        .star-field {
            position: fixed; top: 0; left: 0; width: 100%; height: 100%;
            z-index: -1; pointer-events: none;
        }

        /* --- UI CARDS --- */
        .master-container { width: 100%; max-width: 450px; padding: 20px; z-index: 1000; position: relative; }

        .card {
            background: rgba(15, 23, 42, 0.9);
            backdrop-filter: blur(25px);
            -webkit-backdrop-filter: blur(25px);
            padding: 40px 25px;
            border-radius: 45px;
            border: 1px solid rgba(255, 255, 255, 0.2);
            text-align: center;
            box-shadow: 0 0 50px rgba(0, 210, 255, 0.15);
            animation: cardEntrance 0.8s cubic-bezier(0.34, 1.56, 0.64, 1);
            position: relative;
            z-index: 9000; /* Paling tinggi agar tidak tertutup apa pun */
        }

        @keyframes cardEntrance {
            from { opacity: 0; transform: translateY(80px) scale(0.7); }
            to { opacity: 1; transform: translateY(0) scale(1); }
        }

        .hidden { display: none !important; }

        /* --- TEXT STYLES --- */
        h1 {
            font-size: 38px; font-weight: 800;
            background: linear-gradient(to right, var(--neon-blue), #fff, var(--neon-pink));
            -webkit-background-clip: text; -webkit-text-fill-color: transparent;
            margin-bottom: 5px; filter: drop-shadow(0 0 15px rgba(0, 210, 255, 0.6));
        }
        .subtitle { 
            font-size: 11px; font-weight: 800; color: var(--neon-blue);
            text-transform: uppercase; letter-spacing: 4px; margin-bottom: 30px; display: block;
        }

        /* --- INPUTS & BUTTONS --- */
        .form-group { text-align: left; margin-bottom: 20px; }
        label { font-size: 10px; font-weight: 700; color: rgba(255,255,255,0.5); text-transform: uppercase; margin-bottom: 8px; display: block; margin-left: 10px; }
        
        input, select {
            width: 100%; padding: 18px; border-radius: 20px;
            border: 1px solid rgba(255,255,255,0.15);
            background: rgba(255, 255, 255, 0.08); color: #fff;
            font-size: 14px; font-weight: 600; transition: 0.3s;
        }
        input:focus { border-color: var(--neon-blue); background: rgba(255,255,255,0.15); outline: none; }
        option { background: #0f172a; color: #fff; }

        .btn-action {
            background: linear-gradient(135deg, var(--neon-pink), #a21caf);
            color: white; border: none; padding: 22px; border-radius: 22px;
            font-size: 16px; font-weight: 800; cursor: pointer; width: 100%;
            text-transform: uppercase; letter-spacing: 2px;
            box-shadow: 0 10px 30px rgba(255, 0, 85, 0.4);
            margin-top: 10px; transition: 0.3s;
        }
        .btn-action:hover { transform: translateY(-3px); box-shadow: 0 15px 40px rgba(255, 0, 85, 0.6); }

        .btn-opt { 
            flex: 1; padding: 18px; border-radius: 18px; 
            border: 1px solid rgba(255,255,255,0.1);
            background: rgba(255,255,255,0.05); color: #fff;
            font-size: 12px; font-weight: 700; cursor: pointer; transition: 0.3s;
        }

        /* --- FLUID METEOR PHYSICS --- */
        #visual-meteor {
            position: fixed; top: -700px; left: 120%; transform: rotate(45deg);
            z-index: 500; display: none; pointer-events: none;
        }
        .meteor-head {
            width: 120px; height: 120px; 
            background: radial-gradient(circle at 30% 30%, #fff, var(--neon-pink), #200020);
            border-radius: 50%; box-shadow: 0 0 100px var(--neon-pink);
            animation: wobble 0.2s infinite;
        }
        @keyframes wobble { 0%, 100% { transform: translate(0,0); } 50% { transform: translate(3px, -3px); } }
        
        .meteor-tail {
            position: absolute; top: -550px; left: 50%; transform: translateX(-50%);
            width: 80px; height: 700px;
            background: linear-gradient(to bottom, transparent, var(--neon-pink), #fde047);
            filter: blur(30px); opacity: 0.9;
        }
        .meteor-slam { display: block !important; animation: cosmicSlam 2.5s cubic-bezier(0.4, 0, 0.2, 1) forwards; }
        
        @keyframes cosmicSlam {
            0% { top: -700px; left: 120%; scale: 0.1; rotate: 0deg; }
            30% { top: 10%; left: 80%; scale: 0.4; rotate: -10deg; }
            100% { top: 150vh; left: -50%; scale: 12; rotate: -45deg; } 
        }

        /* --- IMPACT EFFECTS --- */
        #impact-flash {
            position: fixed; top: 0; left: 0; width: 100%; height: 100%;
            background: #fff; z-index: 99999; opacity: 0; pointer-events: none;
        }
        .flash-active { animation: impactFlashAnim 0.6s ease-out; }
        @keyframes impactFlashAnim { 0% { opacity: 1; } 100% { opacity: 0; } }

        #screen-crack {
            position: fixed; top: 0; left: 0; width: 100%; height: 100%;
            background-image: url('data:image/svg+xml;utf8,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 100 100"><path d="M0,0 L50,50 M100,0 L50,50 M0,100 L50,50 M100,100 L50,50 M30,0 L70,100 M0,70 L100,30 M50,0 L50,100 M0,50 L100,50" stroke="rgba(255,255,255,0.4)" stroke-width="0.3" fill="none"/></svg>');
            background-size: cover; z-index: 50; display: none; pointer-events: none;
        }

        /* --- RESULTS SECTION --- */
        .inisial-giant { 
            font-size: 220px; font-weight: 950; 
            background: linear-gradient(to bottom, #fff, var(--neon-blue));
            -webkit-background-clip: text; -webkit-text-fill-color: transparent;
            filter: drop-shadow(0 0 40px var(--neon-blue));
            margin: -20px 0; font-family: 'serif';
        }
        .res-text { font-size: 22px; font-weight: 700; line-height: 1.5; margin-bottom: 25px; }

        /* --- PROGRESS BAR --- */
        .loading-box { margin: 30px 0; }
        .bar { width: 100%; height: 16px; background: rgba(255,255,255,0.05); border-radius: 50px; overflow: hidden; border: 1px solid rgba(255,255,255,0.1); }
        .fill { height: 100%; width: 0%; background: linear-gradient(to right, var(--neon-blue), var(--neon-pink)); animation: fillProg 3.5s linear forwards; }
        @keyframes fillProg { to { width: 100%; } }

        .shake-extreme { animation: intenseShake 0.6s cubic-bezier(.36,.07,.19,.97) both; }
        @keyframes intenseShake {
            10%, 90% { transform: translate3d(-5px, 5px, 0); }
            30%, 50%, 70% { transform: translate3d(-12px, 12px, 0); }
            40%, 60% { transform: translate3d(12px, -12px, 0); }
        }
    </style>
</head>
<body id="master-body">

    <div class="nebula"></div>
    <div class="star-field" id="stars"></div>
    <div id="impact-flash"></div>
    <div id="visual-meteor"><div class="meteor-tail"></div><div class="meteor-head"></div></div>
    <div id="screen-crack"></div>

    <div class="master-container">
        <div class="card" id="step-1">
            <h1>KUNCORO APP</h1>
            <span class="subtitle">Ultimate Galactic Overdrive</span>
            
            <div class="form-group">
                <label>Nama Target:</label>
                <input type="text" id="in-nama" placeholder="Siapa namamu, Bro?">
            </div>

            <div class="form-group">
                <label>Status Hubungan:</label>
                <select id="in-gender">
                    <option value="">-- Pilih Takdir --</option>
                    <option value="pria">Satria Friendzone (Pria)</option>
                    <option value="wanita">Dewi Overthinking (Wanita)</option>
                </select>
            </div>

            <div class="form-group">
                <label>Partner Petualang:</label>
                <select id="in-hewan">
                    <option value="naga">Naga Indosiar (Ancient)</option>
                    <option value="capy">Capybara Masbro (Chill)</option>
                    <option value="kucing">Kucing Oren (Chaos)</option>
                    <option value="beo">Burung Beo (Si Paling Cepu)</option>
                </select>
            </div>

            <div class="form-group">
                <label>Hobi Utama:</label>
                <select id="in-hobi">
                    <option value="mabar">Mabar (Push Rank Dosa)</option>
                    <option value="stalking">Stalking (FBI Skill)</option>
                    <option value="ngopi">Ngopi (Gaya Elit Ekonomi Sulit)</option>
                    <option value="rebahan">Rebahan (Atlet Kasur)</option>
                </select>
            </div>

            <button class="btn-action" onclick="startAnalysis()">ANALISA SEMESTA 🔮</button>
        </div>

        <div class="card hidden" id="step-loading">
            <h2 style="font-size: 50px;">☄️</h2>
            <h2 style="margin: 20px 0;">MENGINTIP TAKDIR...</h2>
            <div class="loading-box"><div class="bar"><div class="fill"></div></div></div>
            <p style="font-size: 13px; opacity: 0.6;">Menghubungkan ke satelit aib Kuncoro...</p>
        </div>

        <div class="card hidden" id="layer-result">
            <p id="res-badge" style="font-weight: 800; color: var(--neon-blue); text-transform: uppercase; margin-bottom: 15px; letter-spacing: 2px;">[ Processing ]</p>
            <div id="res-text" style="font-size: 22px; font-weight: 700; line-height: 1.5; margin-bottom: 25px; min-height: 100px;">?</div>
            
            <div style="display:flex; gap:12px;">
                <button class="btn-opt" onclick="nextStep()" style="background: var(--neon-blue); border:none; color: #000;">LANJUT ➡️</button>
                <button class="btn-opt" onclick="toggleRoast()">APA IYA?</button>
            </div>
            <p id="res-roast" style="display:none; margin-top:20px; color: var(--neon-pink); font-weight: 700; font-style: italic;">?</p>
        </div>

        <div class="card hidden" id="step-final">
            <span class="subtitle" style="color: var(--neon-pink);">Destiny Unlocked</span>
            <p style="margin-top: 10px; font-weight: 700; color: rgba(255,255,255,0.7); letter-spacing: 1px;">INISIAL JODOH ANDA:</p>
            <div class="inisial-giant" id="res-inisial">?</div>
            <div id="res-jodoh-desc" style="font-size: 18px; font-weight: 700; margin-bottom: 30px; margin-top: 10px;">?</div>
            <button class="btn-action" onclick="showEnding()">TERIMA KASIH ➡️</button>
        </div>

        <div class="card hidden" id="step-ending">
            <h1 style="font-size: 32px; color: #fbbf24;">PESAN DEV ✨</h1>
            <div id="ending-msg" style="margin: 30px 0; font-style: italic; font-weight: 700; font-size: 18px; line-height: 1.6;">?</div>
            <button class="btn-action" style="background: #fbbf24; color: #000;" onclick="location.reload()">COBA LAGI 🔄</button>
        </div>
    </div>

    <script>
        const db = {
            pria: {
                aura: ["Aura kamu bau uap mie instan jam 2 pagi.", "Aura biru kusam, sering di-ghosting pas sayang-sayangnya.", "Beban tim paling berat kalau lagi mabar ML.", "Gengsi chat duluan padahal tiap menit cek story dia."],
                dompet: ["Isi dompet cuma struk parkir tahun lalu.", "Saldo m-banking kamu bikin malaikat nangis liatnya.", "Gaya elit, ekonomi sulit. Makan promag demi skin Epic.", "Dompet tebel isinya cuma kupon Indomaret kadaluarsa."],
                hobi: ["Mabar sampe mata merah tapi rank tetep Bronze.", "Sok-sokan hobi gym padahal cuma foto mirror doang.", "Hobi scrolling TikTok sampe jam 3 pagi nyari asupan galau.", "Hobi modif motor tapi bensin sering minjem temen."],
                percintaan: ["Satria Friendzone! Udah antar jemput eh cuma dianggap abang.", "Lagi nunggu dia peka? Keburu kiamat Bro!", "Raja badut, rela diselingkuhin asal dia gak pergi.", "Chat cuma di-read? Mungkin HP-nya nyemplung ke selokan."]
            },
            wanita: {
                aura: ["Aura bau seblak kerupuk mawar ama parfum 100 semprot.", "Aura 'Terserah', pengen dimengerti tapi mulut dikunci.", "Hobi self-diagnosis lewat TikTok, auranya drakor sedih.", "Baju selemari tapi teriak 'Gak punya baju!'."],
                dompet: ["Keranjang Shopee 99+, isinya barang gak guna.", "Duit abis buat es kopi biar story keliatan produktif.", "Mode hemat nasi, tapi checkout skincare 500rb.", "Saldo dua perak, tapi nangkring di mall demi AC."],
                hobi: ["Nonton drakor 20 episode dalam semalam sampe mata panda.", "Stalking akun cewek yang baru dia follow sampe dapet username ibunya.", "Hobi jajan seblak tapi ngeluh diet tiap pagi.", "Koleksi foto produk di keranjang tapi gak pernah dicheckout."],
                percintaan: ["Dewi Overthinking! Capek mikirin arti emoji '👍'?", "Gampang baper sama cowok Red Flag. Tobat Sist!", "Stalking akun cewek yang baru dia follow ya? Cieee.", "Nunggu pangeran, padahal pangerannya boncengin cewek lain."]
            }
        };

        const roastLines = [
            "Kuncoro: 'Gak usah ngelak, data satelit 100% akurat!'",
            "Kuncoro: 'Halah, algoritma Kuncoro sudah membaca lubuk hatimu yang terdalam.'",
            "Kuncoro: 'Pura-pura nolak padahal dalam hati bilang: Kok bener banget ya?'",
            "Kuncoro: 'Ngaku aja, mau sembunyi di galaksi mana lagi kamu?'",
            "Kuncoro: 'Data aibmu sudah tersinkronisasi, jangan coba-coba mengelak!'"
        ];

        const jodohArr = ["Sabar banget jajanin kamu.", "Wangi tapi takut kecoa.", "Tipe rumahan, maraton drakor bareng.", "Ekstrovert gila, temennya banyak.", "Humoris receh parah, idupmu gak bakal bosen."];

        let currentStep = 0, userData = {}, skor = 0;
        const analysisLayers = [
            {t: "ANALISA AURA", k: "aura"},
            {t: "SCANNER DOMPET", k: "dompet"},
            {t: "INVESTIGASI HOBI", k: "hobi"},
            {t: "TAKDIR ASMARA", k: "percintaan"}
        ];

        // Cosmic Star Field
        const starBox = document.getElementById('stars');
        for(let i=0; i<120; i++) {
            const s = document.createElement('div');
            s.style.position = 'absolute';
            s.style.background = '#fff';
            s.style.width = s.style.height = Math.random()*2+'px';
            s.style.top = Math.random()*100+'%';
            s.style.left = Math.random()*100+'%';
            s.style.borderRadius = '50%';
            s.style.opacity = Math.random();
            starBox.appendChild(s);
        }

        function startAnalysis() {
            const nama = document.getElementById('in-nama').value.trim();
            const gender = document.getElementById('in-gender').value;
            if(!nama || !gender) return alert("Isi nama dan takdir dulu!");

            userData = { nama, gender };
            for(let i=0; i<nama.length; i++) skor += nama.charCodeAt(i);

            document.getElementById('step-1').classList.add('hidden');
            document.getElementById('step-loading').classList.remove('hidden');

            setTimeout(() => {
                document.getElementById('step-loading').classList.add('hidden');
                document.getElementById('layer-result').classList.remove('hidden');
                showStepData();
            }, 3500);
        }

        function showStepData() {
            const layer = analysisLayers[currentStep];
            document.getElementById('res-badge').innerText = `[ ${layer.t} ]`;
            document.getElementById('res-text').innerText = db[userData.gender][layer.k][skor % 4];
            document.getElementById('res-roast').style.display = 'none';
        }

        function nextStep() {
            if(currentStep < analysisLayers.length - 1) {
                currentStep++; showStepData();
            } else {
                meteorStrike();
            }
        }

        function toggleRoast() {
            const r = document.getElementById('res-roast');
            r.innerText = roastLines[Math.floor(Math.random() * roastLines.length)];
            r.style.display = 'block';
        }

        function meteorStrike() {
            document.getElementById('layer-result').classList.add('hidden');
            const m = document.getElementById('visual-meteor');
            m.classList.add('meteor-slam');

            // Impact Timing
            setTimeout(() => {
                document.getElementById('impact-flash').classList.add('flash-active');
                document.getElementById('master-body').classList.add('shake-extreme');
                document.getElementById('screen-crack').style.display = 'block';
                
                // Hide meteor after impact to prevent blocking
                setTimeout(() => { m.style.display = 'none'; }, 200);

                setTimeout(() => {
                    document.getElementById('step-final').classList.remove('hidden');
                    document.getElementById('res-inisial').innerText = String.fromCharCode(65 + (skor % 26));
                    document.getElementById('res-jodoh-desc').innerText = jodohArr[skor % 5];
                }, 100);
            }, 2400); 
        }

        function showEnding() {
            document.getElementById('step-final').classList.add('hidden');
            document.getElementById('step-ending').classList.remove('hidden');
            const msg = document.getElementById('ending-msg');
            msg.innerText = (userData.gender === 'wanita') ? 
                "Terima kasih sudah menggunakan Kuncoro App. Puteri Seblak, daripada mikirin dia, mending kasih saweran ke dev biar aplikasi ini makin jago ngeroast kamu!" :
                "Makasih udah mampir, Satria Friendzone. Daripada kasih harapan palsu ke gebetan, mending kasih saweran ke developer biar gak jomblo juga kaya kamu!";
        }
    </script>
</body>
</html>
